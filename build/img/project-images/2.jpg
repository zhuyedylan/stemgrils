<script type="text/javascript">
         function check(form) {

            var m=$('input[name=m]').val();
            var c=$('input[name=c]').val();
            var a=$('input[name=a]').val();
            var sou=$('input[name=sou]').val();

             if(m!='content'){
                alert('非法操作');
                return false;
            }
             if(c!='index'){
                alert('非法操作');
                return false;
            }
             if(a!='serch'){
                alert('非法操作');
                return false;
            }
             if(sou!='ss'){
                alert('非法操作');
                return false;
            }

         return true;
         }
</script>
