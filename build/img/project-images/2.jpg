  /* 漂浮的招聘公告按钮 */
  .recruitment-float {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #972450;
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    box-shadow: 0 10px 20px rgba(151, 36, 80, 0.35);
    z-index: 1000;
    font-weight: 600;
    letter-spacing: 0.2px;
    transform: translateZ(0);
    animation: floatY 3s ease-in-out infinite;
    text-align: center;
  }
  .recruitment-float:hover { filter: brightness(1.05); }
  .recruitment-float:active { transform: translateY(1px); }
  .badge {
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
  }
  @keyframes floatY {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  @media (max-width: 480px) {
    .recruitment-float { right: 16px; bottom: 16px; padding: 10px 14px; }
  }
