  })
</script>

<script type='text/javascript'>
  $(function () {
    cp = 0;
    cp2 = 0;
    cp3 = 0;
    cp4 = 0;

    // 获取li数量
    var aa = document.getElementById("he").getElementsByTagName("li").length;
    var bb = document.getElementById("mei").getElementsByTagName("li").length;
    var cc = document.getElementById("ming").getElementsByTagName("li").length;
    var dd = document.getElementById("zuo").getElementsByTagName("li").length;
    var ee = document.getElementById("zhuan").getElementsByTagName("li").length;
    // 获取指定的class名称

    function run() {
      cp++;
      if (cp == 3) {
        $('.qiye').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clies li').eq(0).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
        cp = 0;
      }
      var lr = -990.5 * cp;
      $('.qiye').stop().animate({ 'left': lr + 'px' }, 1000);
      $('.clies li').eq(cp).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
    }
    function run1() {
      cp2++;
      if (cp2 == 3) {

        $('.meiti').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clie li').eq(0).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });
        cp2 = 0;
      }

      var lr = -990.5 * cp2;
      $('.meiti').stop().animate({ 'left': lr + 'px' }, 1000);
      $('.clie li').eq(cp2).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });

    }

    function run2() {
      cp3++;
      if (cp3 == 3) {
        $('.hezuo').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clies3 li').eq(0).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });
        cp3 = 0;
      }
      var lr = -990.5 * cp3;
      $('.hezuo').stop().animate({ 'left': lr + 'px' }, 1000);
      $('.clies3 li').eq(cp3).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });
    }

    function run3() {
      cp4++;
      if (cp4 == 3) {
        $('.zhuanye').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clies4 li').eq(0).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });
        cp4 = 0;
      }
      var lr = -990.5 * cp4;
      $('.zhuanye').stop().animate({ 'left': lr + 'px' }, 1000);
      $('.clies4 li').eq(cp4).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });
    }


    var time = setInterval(run, 6000);
    // 1
    $('.clies').mouseover(function () {
      clearInterval(time);
    })
    $('.clies').mouseout(function () {

      time = setInterval(run, 6000);
    })
    $('.po1').click(function () {
      $('.qiye').stop().animate({ 'left': 0 + 'px' }, 10);
      $('.clies li').eq(0).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
      cp = 0;
    })
    $('.po2').click(function () {
      $('.meiti').stop().animate({ 'left': 0 + 'px' }, 10);
      $('.clie li').eq(0).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });
      cp2 = 0;
    })

    $('.po3').click(function () {

      $('.hezuo').stop().animate({ 'left': 0 + 'px' }, 10);
      $('.clies3 li').eq(0).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });
      cp3 = 0;
    })

    $('.po4').click(function () {

      $('.zhuanye').stop().animate({ 'left': 0 + 'px' }, 10);
      $('.clies4 li').eq(0).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });
      cp4 = 0;
    })
    $('#op2').click(function () {

      var time2 = setInterval(run1, 6000);
      $('.clie').mouseover(function () {
        clearInterval(time2);
      })
      $('.clie').mouseout(function () {
        time2 = setInterval(run1, 6000);
      })
      //清除掉以前绑定在click上的事件
      $('#op2').unbind('click');


    })

    $('#op3').click(function () {
      var time3 = setInterval(run2, 6000);
      // 清除定时器
      $('.clies3').mouseover(function () {
        clearInterval(time3);
      })
      $('.clies3').mouseout(function () {
        time3 = setInterval(run2, 6000);
      })
      $('#op3').unbind('click');
    })

    $('#op4').click(function () {


      var time4 = setInterval(run3, 6000);
      // 清除定时器
      $('.clies4').mouseover(function () {
        clearInterval(time4);
      })
      $('.clies4').mouseout(function () {
        time4 = setInterval(run3, 6000);
      })
      $('#op4').unbind('click');
    })

    // $('.clies li').live("click", function () {
    //   cp = $(this).index();
    //
    //   if (cp == 0 && aa <= 7 || cp == 0 && aa > 7) {
    //
    //     $('.qiye').stop().animate({ 'left': 0 + 'px' }, 1000);
    //     $('.clies li').eq(cp).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
    //   }
    //   if (cp == 1 && aa > 7 && aa < 22) {
    //
    //     $('.qiye').stop().animate({ 'left': -991 + 'px' }, 1000);
    //     $('.clies li').eq(cp).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
    //   }
    //   if (cp == 2 && aa > 14 && aa < 22) {
    //
    //     $('.qiye').stop().animate({ 'left': -1981 + 'px' }, 1000);
    //     $('.clies li').eq(cp).css({ 'background': '#972450' }).siblings('.clies li').css({ 'background': '#5e5e5e' });
    //   }
    // })


    // $('.clie li').live("click", function () {
    //
    //   cp2 = $(this).index();
    //
    //   if (cp2 == 0 && bb <= 7 || cp2 == 0 && bb > 7) {
    //
    //     $('.meiti').stop().animate({ 'left': 0 + 'px' }, 1000);
    //     $('.clie li').eq(cp2).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });
    //   }
    //   if (cp2 == 1 && bb > 7 && bb < 22) {
    //
    //     $('.meiti').stop().animate({ 'left': -991 + 'px' }, 1000);
    //     $('.clie li').eq(cp2).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });
    //
    //   }
    //   if (cp2 == 2 && bb > 14 && bb < 22) {
    //
    //     $('.meiti').stop().animate({ 'left': -1981 + 'px' }, 1000);
    //     $('.clie li').eq(cp2).css({ 'background': '#972450' }).siblings('.clie li').css({ 'background': '#5e5e5e' });
    //   }
    // })
    // 清除定时器

    // 3
    $('#links').click(function () {

      window.location.href = "http://www.cwdf.org.cn/index.php?m=content&c=index&a=lists&catid=35";
    })

    // 4
    $('.clies3 li').on("click", function () {

      cp3 = $(this).index();

      if (cp3 == 0 && dd <= 7 || cp3 == 0 && dd > 7) {

        $('.hezuo').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clies3 li').eq(cp3).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });
      }
      if (cp3 == 1 && dd > 7 && dd < 22) {

        $('.hezuo').stop().animate({ 'left': -991 + 'px' }, 1000);
        $('.clies3 li').eq(cp3).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });

      }
      if (cp3 == 2 && dd > 14 && dd < 22) {

        $('.hezuo').stop().animate({ 'left': -1981 + 'px' }, 1000);
        $('.clies3 li').eq(cp3).css({ 'background': '#972450' }).siblings('.clies3 li').css({ 'background': '#5e5e5e' });
      }
    })


    // 5

    $('.clies4 li').on("click", function () {

      cp4 = $(this).index();

      if (cp4 == 0 && ee <= 7 || cp4 == 0 && ee > 7) {

        $('.zhuanye').stop().animate({ 'left': 0 + 'px' }, 1000);
        $('.clies4 li').eq(cp4).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });
      }
      if (cp4 == 1 && ee > 7 && ee < 22) {

        $('.zhuanye').stop().animate({ 'left': -991 + 'px' }, 1000);
        $('.clies4 li').eq(cp4).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });

      }
      if (cp4 == 2 && ee > 14 && ee < 22) {

        $('.zhuanye').stop().animate({ 'left': -1981 + 'px' }, 1000);
        $('.clies4 li').eq(cp4).css({ 'background': '#972450' }).siblings('.clies4 li').css({ 'background': '#5e5e5e' });
      }
    });

    var __index = 0;
    var __timer;
    function autoplay() {
      __timer = setInterval(function() {
        __index++; //index递增
        if (__index === 2) __index = 0;
        $(".header-20>li").eq(__index).fadeIn(600).addClass("current").siblings().fadeOut(1000).removeClass("current");
      }, 5000);
    }
    autoplay(); //调用函数，开启定时器
  })
